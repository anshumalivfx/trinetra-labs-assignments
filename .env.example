# Application
APP_NAME=AI Agent Orchestration System
ENVIRONMENT=development
DEBUG=True
API_VERSION=v1
SECRET_KEY=your-secret-key-here-change-in-production

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/agent_orchestration
DB_ECHO=False

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=10

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Mistral AI
MISTRAL_API_KEY=your-mistral-api-key-here
MISTRAL_MODEL=open-mixtral-8x7b

# Email Configuration
# Choose: sendgrid or smtp (Gmail, Outlook, etc.)
EMAIL_PROVIDER=smtp

# SendGrid (if using EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=your-sendgrid-api-key-here

# SMTP Configuration (if using EMAIL_PROVIDER=smtp)
# For Gmail: Use App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
EMAIL_FROM=your-email@gmail.com

# File Upload
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=./uploads

# Performance
WORKER_TIMEOUT=300
MAX_CONCURRENT_JOBS=10

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
